# PostGenie environment variables
# Copy to .env and fill in your values

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Google OAuth (for user login) ───
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-secret
GOOGLE_REDIRECT_URI=http://localhost:8501/

# ─── Blogger OAuth (can be same as above or different) ───
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=

# ─── Claude API ───
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Paddle (for subscriptions - get from Paddle dashboard) ───
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PRICE_BASIC_MONTHLY=pri_...
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_AGENCY_MONTHLY=pri_...
